<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Write a Post</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container py-5">
      <div class="editor-shell mx-auto">
        <div class="mb-4">
          <p class="section-label mb-1">Editorial desk</p>
          <h1 class="section-title mb-2">Write something worth reading</h1>
          <p class="text-muted mb-0">
            Share a project story, a lesson learned, or a thoughtful update.
          </p>
        </div>
        <% if (locals.imageKitMessage) { %>
        <div class="alert <%= imageKitReady ? 'alert-success' : 'alert-warning' %>" role="alert">
          <%= imageKitMessage %>
        </div>
        <% } %>
        <form action="/blog" method="post" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="coverImage" class="form-label">Cover Image</label>
          <input
            type="file"
            class="form-control"
            id="coverImage"
            name="coverImage"
            aria-describedby="coverImage"
            accept="image/*"
          />
          <div class="form-text">
            Images are uploaded to ImageKit so they remain available after deployment.
          </div>
        </div>
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            class="form-control"
            id="title"
            name="title"
            aria-describedby="title"
          />
        </div>
        <div class="mb-3">
          <label for="body">Story</label>
          <textarea name="body" class="form-control" id="body" rows="10"></textarea>
        </div>
        <div class="mb-3">
          <button class="btn btn-accent">Publish post</button>
        </div>
      </form>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
